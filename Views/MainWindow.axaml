<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Keysharp.Views.MainWindow"
        Title="Keysharp"
        Width="1000"
        Height="700"
        WindowStartupLocation="CenterScreen">
    <Grid RowDefinitions="Auto,*,4,*" ColumnDefinitions="200,4,*">
        <!-- Header -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" 
                Background="#2D2D30" 
                BorderBrush="#3F3F46" 
                BorderThickness="0,0,0,1"
                Padding="15,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Keysharp" 
                           FontSize="20" 
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <TextBlock Text=" - Application" 
                           FontSize="16"
                           Foreground="#CCCCCC"
                           VerticalAlignment="Center"
                           Margin="5,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Sidebar -->
        <Border Grid.Row="1" Grid.RowSpan="3" Grid.Column="0" 
                Background="#252526" 
                BorderBrush="#3F3F46" 
                BorderThickness="0,0,1,0">
            <StackPanel Margin="10" Spacing="10">
                <TextBlock Text="Navigation" 
                           FontSize="16" 
                           FontWeight="SemiBold"
                           Foreground="White"
                           Margin="0,0,0,10"/>
                <Button Content="Home" 
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="10,8"
                        Margin="0,0,0,5"/>
                <Button Content="Settings" 
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="10,8"
                        Margin="0,0,0,5"/>
                <Button Content="About" 
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="10,8"/>
            </StackPanel>
        </Border>

        <!-- Vertical Splitter (between sidebar and main content) -->
        <GridSplitter Grid.Row="1" Grid.RowSpan="3" Grid.Column="1"
                      Background="#3F3F46"
                      Width="4"
                      ShowsPreview="False"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ResizeDirection="Columns"/>

        <!-- Main Content Area with Tabs -->
        <Border Grid.Row="1" Grid.Column="2" 
                Background="#1E1E1E">
            <TabControl Background="Transparent"
                        BorderThickness="0">
                <TabControl.Styles>
                    <Style Selector="TabItem">
                        <Setter Property="Background" Value="#252526"/>
                        <Setter Property="Foreground" Value="#CCCCCC"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="15,8"/>
                        <Setter Property="Margin" Value="0,0,2,0"/>
                        <Setter Property="FontSize" Value="12"/>
                    </Style>
                    <Style Selector="TabItem:selected">
                        <Setter Property="Background" Value="#1E1E1E"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Style>
                    <Style Selector="TabItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#2D2D30"/>
                    </Style>
                </TabControl.Styles>
                
                <!-- Tab 1: Home -->
                <TabItem Header="Home">
                    <ScrollViewer>
                        <StackPanel Margin="20" Spacing="15">
                            <TextBlock Text="Home" 
                                       FontSize="24" 
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="Welcome to Keysharp!" 
                                       FontSize="18" 
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,10,0,5"/>
                            <TextBlock Text="This is the home tab. You can add your main content here." 
                                       FontSize="14"
                                       Foreground="#CCCCCC"
                                       TextWrapping="Wrap"/>
                            <Separator Margin="0,20"/>
                            <TextBlock Text="Features:" 
                                       FontSize="16" 
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,10,0,5"/>
                            <TextBlock Text="• Three-panel layout with adjustable panels&#x0a;• Tab-based navigation&#x0a;• Modern dark theme" 
                                       FontSize="14"
                                       Foreground="#CCCCCC"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                
                <!-- Tab 2: Documents -->
                <TabItem Header="Documents">
                    <ScrollViewer>
                        <StackPanel Margin="20" Spacing="15">
                            <TextBlock Text="Documents" 
                                       FontSize="24" 
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="Document management area" 
                                       FontSize="14"
                                       Foreground="#CCCCCC"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,0"/>
                            <Separator Margin="0,20"/>
                            <TextBlock Text="No documents yet." 
                                       FontSize="14"
                                       Foreground="#999999"
                                       FontStyle="Italic"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                
                <!-- Tab 3: Settings -->
                <TabItem Header="Settings">
                    <ScrollViewer>
                        <StackPanel Margin="20" Spacing="15">
                            <TextBlock Text="Settings" 
                                       FontSize="24" 
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="Application settings and preferences" 
                                       FontSize="14"
                                       Foreground="#CCCCCC"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,0"/>
                            <Separator Margin="0,20"/>
                            <StackPanel Spacing="10">
                                <CheckBox Content="Enable notifications" 
                                          Foreground="White"/>
                                <CheckBox Content="Auto-save documents" 
                                          Foreground="White"/>
                                <CheckBox Content="Dark theme" 
                                          Foreground="White"
                                          IsChecked="True"
                                          IsEnabled="False"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Border>

        <!-- Horizontal Splitter (between main content and lower panel) -->
        <GridSplitter Grid.Row="2" Grid.Column="2"
                      Background="#3F3F46"
                      Height="4"
                      ShowsPreview="False"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ResizeDirection="Rows"/>

        <!-- Lower Panel -->
        <Border Grid.Row="3" Grid.Column="2" 
                Background="#252526" 
                BorderBrush="#3F3F46" 
                BorderThickness="0,1,0,0"
                Padding="15,10">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Status: " 
                               FontSize="12"
                               Foreground="#CCCCCC"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Ready" 
                               FontSize="12"
                               Foreground="#4EC9B0"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Version 1.0.0" 
                               FontSize="12"
                               Foreground="#999999"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

